# Copy this file to .env and fill in the keys you want to use.
# The app works with any subset — debaters without a key will show a config error.

# Anthropic — Claude debater & default facilitator
ANTHROPIC_API_KEY=process.env.ANTHROPIC_API_KEY

# OpenAI — GPT debater
OPENAI_API_KEY=process.env.OPENAI_API_KEY

# xAI — Grok debater (OpenAI-compatible endpoint)
GROK_API_KEY=xprocess.env.GROK_API_KEY

# Google — Gemini debater
GEMINI_API_KEY=process.env.GEMINI_API_KEY

# Optional: change the default port (default: 5000)
# PORT=5000
